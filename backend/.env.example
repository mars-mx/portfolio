# Komma-separierte Liste erlaubter Frontend-Origins (CORS)
CORS_ORIGINS=http://localhost:3210

# Modell des Chat-Assistenten: provider-agnostischer Pydantic-AI-String
# ("<provider>:<modell>"). Optionaler Override, Default: openai:gpt-5.5.
# Anderer Provider braucht ggf. das passende Extra:
#   uv add "pydantic-ai-slim[<provider>,ui]"
# AI_MODEL=openai:gpt-5.4-mini

# OpenAI-Embedding-Modell für die Wissensbasis-Suche. Optionaler Override,
# Default: text-embedding-3-small.
# EMBEDDING_MODEL=text-embedding-3-small

# Native Websuche des Modells (OpenAI Responses API). Vorher in der
# OpenAI-Organisation die Hosted Tools freischalten:
# https://platform.openai.com/settings/organization/data-controls/hosted-tools
# WEB_SEARCH=true

# Cloudflare Turnstile (Bot-Schutz für den Chat). Sobald der Secret Key
# gesetzt ist, verlangt /api/chat eine bestandene Challenge — im Frontend
# muss dann der passende NEXT_PUBLIC_TURNSTILE_SITE_KEY gesetzt sein.
# Leer/nicht gesetzt = Schutz aus.
# TURNSTILE_SECRET_KEY=0x...

# Google-Kalender-Buchungsseite für das Chat-Tool offer_booking. Lebt bewusst
# nur im Backend: der Link erreicht den Browser nur als Tool-Ergebnis über den
# (per Turnstile schützbaren) Chat-Stream. Die Schedule-URL (Redirect-Ziel des
# calendar.app.google-Kurzlinks) ist als Kalender-Widget im Chat einbettbar;
# ein Kurzlink funktioniert auch, rendert aber nur einen Button.
# Leer/nicht gesetzt = Tool deaktiviert.
# BOOKING_URL=https://calendar.google.com/calendar/appointments/schedules/...

# Provider-API-Key: Pydantic AI und das OpenAI-SDK lesen ihn direkt aus der
# Prozessumgebung. Im Deployment als Secret setzen. Lokal laden die make-Targets
# diese Datei per `uv run --env-file` — der Key darf hier also stehen:
# OPENAI_API_KEY=sk-...   (bzw. ANTHROPIC_API_KEY=... usw.)
