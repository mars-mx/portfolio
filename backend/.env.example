# Komma-separierte Liste erlaubter Frontend-Origins (CORS)
CORS_ORIGINS=http://localhost:3210

# Modell des Chat-Assistenten: provider-agnostischer Pydantic-AI-String
# ("<provider>:<modell>"). Optionaler Override, Default: openai:gpt-5.5.
# Anderer Provider braucht ggf. das passende Extra:
#   uv add "pydantic-ai-slim[<provider>,ui]"
# AI_MODEL=openai:gpt-5.4-mini

# OpenAI-Embedding-Modell für die Wissensbasis-Suche. Optionaler Override,
# Default: text-embedding-3-small.
# EMBEDDING_MODEL=text-embedding-3-small

# Provider-API-Key: Pydantic AI und das OpenAI-SDK lesen ihn direkt aus der
# Prozessumgebung. Im Deployment als Secret setzen. Lokal laden die make-Targets
# diese Datei per `uv run --env-file` — der Key darf hier also stehen:
# OPENAI_API_KEY=sk-...   (bzw. ANTHROPIC_API_KEY=... usw.)
